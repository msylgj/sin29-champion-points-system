# Database Configuration
DB_USER=archery_user
DB_PASSWORD=archery_pass
DB_NAME=archery_db
DB_PORT=5432

# Service Ports
BACKEND_PORT=8000
FRONTEND_PORT=8080

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api
# Vite 开发服务器允许访问的域名，多个值用逗号分隔
# 示例: VITE_ALLOWED_HOSTS=router.msylgj.top,localhost
VITE_ALLOWED_HOSTS=router.msylgj.top

# Secret key
# echo -n '你的明文密码' | sha256sum | awk '{print $1}'
SECRET_KEY=replace_with_sha256_hex
